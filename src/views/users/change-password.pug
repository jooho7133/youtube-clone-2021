extends ../base

block content
    if errorMessage
        span=errorMessage
    form(method="POST")
        input(placeholder="Old Password", name="password", type="password", required)
        input(placeholder="New Password", name="password1", type="password", required)
        input(placeholder="New Password Confirmation", name="password3", type="password", required)
        input(type="submit", value="Change Password")